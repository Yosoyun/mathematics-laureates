---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy"
  description="Privacy behaviour for the static archive."
>
  <section class="container py-14">
    <p class="eyebrow">Privacy</p>
    <h1 class="section-title mt-3">No accounts, no behavioural tracking</h1>
    <div class="prose-archive mt-8 max-w-3xl">
      <p>
        This site is designed as a static archive. It does not require user
        accounts, paid APIs, private runtime services, or behavioural analytics.
      </p>
      <p>
        The theme preference is stored locally in the browser. Search runs
        locally against a static index. External links lead to source websites
        with their own policies.
      </p>
    </div>
  </section>
</BaseLayout>
