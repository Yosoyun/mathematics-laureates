---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Corrections"
  description="Submit corrections to the archive."
>
  <section class="container py-14">
    <p class="eyebrow">Corrections</p>
    <h1 class="section-title mt-3">Corrections need evidence</h1>
    <div class="prose-archive mt-8 max-w-3xl">
      <p>
        If a record is wrong or incomplete, submit the page URL, the exact
        sentence or data field, the corrected value, and a reliable source URL.
        Corrections that involve identity, affiliation, quotations, images, or
        prize money require especially careful sourcing.
      </p>
      <p>
        The archive's default response to uncertainty is to mark the field
        incomplete rather than guess.
      </p>
    </div>
  </section>
</BaseLayout>
