---
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "@lib/paths";
---

<BaseLayout title="Page not found">
  <section class="directory-hero py-24">
    <div class="container relative z-10">
      <p class="eyebrow">404</p>
      <h1 class="section-title mt-3">This page is not in the archive</h1>
      <p class="mt-5 max-w-xl leading-7 text-muted">
        Try the search box, awards directory, laureate directory, or sources
        page.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 text-sm font-bold">
        <a class="btn-quiet" href={withBase("/")}>Home</a>
        <a class="btn-quiet" href={withBase("/awards")}>Awards</a>
      </div>
    </div>
  </section>
</BaseLayout>
