---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About The Laureate Equation.">
  <section class="container py-14">
    <p class="eyebrow">About</p>
    <h1 class="section-title mt-3">
      A digital museum for mathematical honours
    </h1>
    <div class="prose-archive mt-8 max-w-3xl">
      <p>
        The Laureate Equation is a static, open, source-conscious archive for
        major mathematics and statistics awards. It is designed for students,
        educators, researchers, historians, and enthusiasts who want context
        rather than a bare list of names.
      </p>
      <p>
        The archive avoids advertising, rankings of people, private tracking,
        and unsourced biographical claims. It favours transparent data coverage
        and contribution workflows.
      </p>
    </div>
  </section>
</BaseLayout>
