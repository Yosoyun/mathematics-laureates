---
import {
  ArrowRight,
  BookOpen,
  Compass,
  MapPinned,
  Sparkles,
} from "lucide-astro";
import AwardCard from "@components/AwardCard.astro";
import LaureateCard from "@components/LaureateCard.astro";
import SearchBox from "@components/SearchBox.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { awards, laureates, winnerRecords } from "@lib/catalog";
import { withBase } from "@lib/paths";

const featuredAwards = awards.slice(0, 6);
const featuredLaureates = laureates.slice(0, 6);
const recentWinners = [...winnerRecords]
  .sort((a, b) => b.year - a.year)
  .slice(0, 8);
---

<BaseLayout title="The Minds, Ideas and Honours That Shaped Mathematics">
  <section
    class="hero-shell"
    style={`--hero-image: url("${withBase("/images/laureate-hero.jpg")}")`}
  >
    <div class="hero-content container">
      <div class="hero-copy">
        <p class="eyebrow">Global mathematics awards archive</p>
        <h1 class="display-title mt-5">
          The Minds, Ideas and Honours That Shaped Mathematics
        </h1>
        <p class="mt-7 max-w-2xl text-xl leading-8 text-[#f2e6d1]">
          Explore the world's major mathematics and statistics awards, the
          people who earned them, and the ideas that transformed human
          knowledge.
        </p>
        <div class="hero-search mt-8">
          <SearchBox featured />
        </div>
        <div class="hero-actions mt-8">
          <a class="btn-primary" href={withBase("/awards")}
            >Browse awards <ArrowRight size={17} /></a
          >
          <a class="btn-secondary" href={withBase("/methodology")}
            >Read methodology <BookOpen size={17} /></a
          >
        </div>
      </div>
      <div class="hero-stats" aria-label="Archive metrics">
        <div class="hero-stat">
          <strong>{awards.length}</strong>
          <span>major awards</span>
        </div>
        <div class="hero-stat">
          <strong>{laureates.length}</strong>
          <span>flagship profiles</span>
        </div>
        <div class="hero-stat">
          <strong>{winnerRecords.length}</strong>
          <span>winner records</span>
        </div>
      </div>
    </div>
  </section>

  <section class="container py-12">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Awards</p>
        <h2 class="section-title mt-3">Featured honours</h2>
      </div>
      <a class="section-link" href={withBase("/awards")}
        >All awards <ArrowRight size={15} /></a
      >
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {featuredAwards.map((award) => <AwardCard award={award} />)}
    </div>
  </section>

  <section class="container py-12">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Laureates</p>
        <h2 class="section-title mt-3">Flagship profiles</h2>
      </div>
      <a class="section-link" href={withBase("/laureates")}
        >All profiles <ArrowRight size={15} /></a
      >
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        featuredLaureates.map((laureate) => (
          <LaureateCard laureate={laureate} />
        ))
      }
    </div>
  </section>

  <section class="container grid gap-8 py-12 lg:grid-cols-[.82fr_1.18fr]">
    <div>
      <p class="eyebrow">Timeline preview</p>
      <h2 class="section-title mt-3">Recent records</h2>
      <p class="mt-4 leading-7 text-muted">
        Use the full timeline to trace award creation, prize years, laureates,
        and research eras with an accessible text alternative.
      </p>
      <a class="btn-quiet mt-6" href={withBase("/timeline")}
        >Open timeline <ArrowRight size={16} /></a
      >
    </div>
    <ol class="timeline-panel card divide-y divide-[var(--line)]">
      {
        recentWinners.map((record) => (
          <li class="grid gap-3 p-4 sm:grid-cols-[5rem_1fr]">
            <>
              <span class="font-display text-3xl leading-none">
                {record.year}
              </span>
              <span>{record.recipientNames.join(", ")}</span>
            </>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="container grid gap-5 py-12 md:grid-cols-3">
    <a class="feature-link card p-6" href={withBase("/fields")}>
      <Compass class="mb-5 text-[var(--accent-cool)]" size={28} />
      <p class="eyebrow">Research-field explorer</p>
      <h2 class="mt-4 font-display text-3xl">
        From algebra to information science
      </h2>
    </a>
    <a class="feature-link card p-6" href={withBase("/world-map")}>
      <MapPinned class="mb-5 text-[var(--accent-warm)]" size={28} />
      <p class="eyebrow">Global map</p>
      <h2 class="mt-4 font-display text-3xl">
        Separate birthplace, affiliation, institution, and award country
      </h2>
    </a>
    <a class="feature-link card p-6" href={withBase("/inspiration")}>
      <Sparkles class="mb-5 text-[var(--accent)]" size={28} />
      <p class="eyebrow">Pathways</p>
      <h2 class="mt-4 font-display text-3xl">Path to Mathematical Greatness</h2>
    </a>
  </section>
</BaseLayout>
