---
import { Search, SlidersHorizontal } from "lucide-astro";
import LaureateCard from "@components/LaureateCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { fields, laureates } from "@lib/catalog";

const fieldOptions = fields.map((field) => ({
  id: field.id,
  name: field.name,
}));
---

<BaseLayout
  title="Laureates"
  description="Browse sourced flagship profiles of mathematics and statistics laureates."
>
  <section class="directory-hero py-14">
    <div class="container relative z-10">
      <p class="eyebrow">Laureate directory</p>
      <h1 class="section-title mt-3">People and research ideas</h1>
      <p class="mt-5 max-w-3xl leading-7 text-muted">
        Profiles separate award-cited mathematical impact from biographical
        details that still need deeper source verification.
      </p>
    </div>
  </section>
  <section class="container py-12">
    <div class="form-panel grid gap-4 p-4 md:grid-cols-[1fr_18rem]">
      <label class="block">
        <span class="inline-flex items-center gap-2 text-sm font-bold"
          ><Search size={16} /> Filter by name, field, or contribution</span
        >
        <input
          class="input-field mt-2 w-full px-3 py-2"
          type="search"
          data-laureate-query
          placeholder="Try 'PDE', 'geometry', or 'Wiles'"
        />
      </label>
      <label class="block">
        <span class="inline-flex items-center gap-2 text-sm font-bold"
          ><SlidersHorizontal size={16} /> Research field</span
        >
        <select class="input-field mt-2 w-full px-3 py-2" data-laureate-field>
          <option value="all">All fields</option>
          {
            fieldOptions.map((field) => (
              <option value={field.id}>{field.name}</option>
            ))
          }
        </select>
      </label>
    </div>
    <div
      class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3"
      data-laureate-grid
    >
      {
        laureates.map((laureate) => (
          <div
            data-laureate-card
            data-fields={laureate.researchFieldIds.join(" ")}
            data-search={`${laureate.fullName} ${laureate.majorContributions.join(" ")} ${laureate.researchFieldIds.join(" ")}`.toLowerCase()}
          >
            <LaureateCard laureate={laureate} />
          </div>
        ))
      }
    </div>
    <p
      class="mt-8 hidden rounded-lg border border-[var(--line)] p-5 text-muted"
      data-laureate-empty
    >
      No profiles match these filters.
    </p>
  </section>
  <script>
    const query = document.querySelector("[data-laureate-query]");
    const field = document.querySelector("[data-laureate-field]");
    const cards = [...document.querySelectorAll("[data-laureate-card]")];
    const empty = document.querySelector("[data-laureate-empty]");

    const applyFilters = () => {
      const q =
        query instanceof HTMLInputElement
          ? query.value.trim().toLowerCase()
          : "";
      const f = field instanceof HTMLSelectElement ? field.value : "all";
      let visible = 0;
      for (const card of cards) {
        const matchesQuery =
          q.length === 0 ||
          (card.getAttribute("data-search") ?? "").includes(q);
        const matchesField =
          f === "all" ||
          (card.getAttribute("data-fields") ?? "").split(" ").includes(f);
        const show = matchesQuery && matchesField;
        card.classList.toggle("hidden", !show);
        if (show) visible += 1;
      }
      empty?.classList.toggle("hidden", visible > 0);
    };

    query?.addEventListener("input", applyFilters);
    field?.addEventListener("change", applyFilters);
  </script>
</BaseLayout>
