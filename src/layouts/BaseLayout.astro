---
import Navigation from "@components/Navigation.astro";
import { withBase } from "@lib/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const siteName = "The Laureate Equation";
const title = Astro.props.title
  ? `${Astro.props.title} | ${siteName}`
  : siteName;
const description =
  Astro.props.description ??
  "A sourced archive of major mathematics and statistics awards, laureates, fields, and research ideas.";
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f6eee2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;600;700;800;900&family=STIX+Two+Text:wght@500;600&display=swap"
    />
    <link rel="icon" href={withBase("/icons/medal.svg")} type="image/svg+xml" />
    <link
      rel="preload"
      as="image"
      href={withBase("/images/laureate-atelier.jpg")}
    />
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const preferredDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      document.documentElement.dataset.theme =
        savedTheme || (preferredDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <div class="reading-progress no-print" id="reading-progress"></div>
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-ivory focus:px-4 focus:py-2 focus:text-ink"
      href="#main">Skip to content</a
    >
    <Navigation />
    <main id="main">
      <slot />
    </main>
    <footer class="mt-24 border-t border-[var(--line)] py-14">
      <div class="container grid gap-10 md:grid-cols-[1.25fr_.8fr_.8fr]">
        <div>
          <p class="eyebrow">Sourced mathematical culture</p>
          <p class="mt-3 font-display text-4xl leading-none">
            The Laureate Equation
          </p>
          <p class="mt-3 max-w-xl text-sm leading-6 text-muted">
            An open, static, source-conscious archive of mathematics and
            statistics awards. Incomplete records are labelled plainly so the
            archive can improve without overstating certainty.
          </p>
        </div>
        <div>
          <p class="font-bold uppercase tracking-[0.14em]">Explore</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li><a href={withBase("/awards")}>Awards</a></li>
            <li><a href={withBase("/laureates")}>Laureates</a></li>
            <li><a href={withBase("/timeline")}>Timeline</a></li>
            <li><a href={withBase("/compare")}>Compare</a></li>
          </ul>
        </div>
        <div>
          <p class="font-bold uppercase tracking-[0.14em]">Trust</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li><a href={withBase("/methodology")}>Methodology</a></li>
            <li><a href={withBase("/sources")}>Sources</a></li>
            <li><a href={withBase("/contribute")}>Contribute</a></li>
            <li><a href={withBase("/privacy")}>Privacy</a></li>
          </ul>
        </div>
      </div>
    </footer>
    <script>
      const progress = document.getElementById("reading-progress");
      const updateProgress = () => {
        const total =
          document.documentElement.scrollHeight - window.innerHeight;
        const ratio = total > 0 ? window.scrollY / total : 0;
        if (progress)
          progress.style.transform = `scaleX(${Math.min(1, Math.max(0, ratio))})`;
      };
      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
      for (const tableWrap of document.querySelectorAll(".table-wrap")) {
        if (!tableWrap.hasAttribute("tabindex"))
          tableWrap.setAttribute("tabindex", "0");
      }
    </script>
  </body>
</html>
