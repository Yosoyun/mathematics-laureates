---
import BaseLayout from "@layouts/BaseLayout.astro";
import { fields, laureatesForField } from "@lib/catalog";
import { withBase } from "@lib/paths";
---

<BaseLayout
  title="Research Fields"
  description="Explore major mathematical fields represented by the awards archive."
>
  <section class="directory-hero py-14">
    <div class="container relative z-10">
      <p class="eyebrow">Research-field explorer</p>
      <h1 class="section-title mt-3">Fields, concepts, and pathways</h1>
      <p class="mt-5 max-w-3xl leading-7 text-muted">
        This field map is deliberately textual first, so it remains usable
        without visualisation support.
      </p>
    </div>
  </section>
  <section class="container py-12">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        fields.map((field) => (
          <article class="card feature-link p-5">
            <p class="card-kicker">
              {laureatesForField(field.id).length} linked profiles
            </p>
            <h2 class="mt-3 font-display text-3xl">
              <a
                class="card-title-link"
                href={withBase(`/fields/${field.slug}`)}
              >
                {field.name}
              </a>
            </h2>
            <p class="mt-3 text-sm leading-6 text-muted">{field.summary}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
