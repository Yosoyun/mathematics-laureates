---
import { ArrowUpRight, Award as AwardIcon } from "lucide-astro";
import CompletenessBadge from "@components/CompletenessBadge.astro";
import type { Award } from "@data/schema";
import { withBase } from "@lib/paths";

interface Props {
  award: Award;
}

const { award } = Astro.props;
---

<article class="award-card card flex h-full flex-col gap-5 p-5">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <span class="brand-mark size-11" aria-hidden="true"
      ><AwardIcon size={19} /></span
    >
    <CompletenessBadge status={award.winnerListStatus} />
  </div>
  <p class="card-kicker">{award.organisation}</p>
  <h2 class="font-display text-3xl leading-none">
    <a class="card-title-link" href={withBase(`/awards/${award.slug}`)}
      >{award.name}</a
    >
  </h2>
  <p class="line-clamp-4 text-sm leading-6 text-muted">{award.description}</p>
  <dl class="meta-grid mt-auto grid-cols-2 text-sm">
    <div>
      <dt class="font-bold">Established</dt>
      <dd class="text-muted">{award.establishedYear}</dd>
    </div>
    <div>
      <dt class="font-bold">Frequency</dt>
      <dd class="text-muted">{award.frequency}</dd>
    </div>
  </dl>
  <a
    class="section-link mt-1 w-fit"
    href={withBase(`/awards/${award.slug}`)}
    aria-label={`Open ${award.name}`}
  >
    Open record <ArrowUpRight size={15} />
  </a>
</article>
