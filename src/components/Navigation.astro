---
import { Medal, MoonStar } from "lucide-astro";
import SearchBox from "@components/SearchBox.astro";
import { withBase } from "@lib/paths";
---

<nav class="nav-shell sticky top-0 z-50">
  <div class="container flex min-h-16 items-center justify-between gap-4 py-3">
    <a
      href={withBase("/")}
      class="flex items-center gap-3 font-bold"
      aria-label="The Laureate Equation home"
    >
      <span class="brand-mark" aria-hidden="true"><Medal size={20} /></span>
      <span class="hidden leading-tight sm:inline">
        <span class="block text-sm uppercase tracking-[0.16em] text-muted"
          >Archive</span
        >
        <span class="block">The Laureate Equation</span>
      </span>
    </a>
    <div class="hidden items-center gap-1 text-sm font-semibold lg:flex">
      <a class="nav-link" href={withBase("/awards")}>Awards</a>
      <a class="nav-link" href={withBase("/laureates")}>Laureates</a>
      <a class="nav-link" href={withBase("/fields")}>Fields</a>
      <a class="nav-link" href={withBase("/timeline")}>Timeline</a>
      <a class="nav-link" href={withBase("/world-map")}>Map</a>
      <a class="nav-link" href={withBase("/compare")}>Compare</a>
    </div>
    <div class="flex items-center gap-2">
      <SearchBox compact />
      <button
        class="icon-button no-print"
        type="button"
        data-theme-toggle
        aria-label="Toggle colour theme"
        title="Toggle theme"
      >
        <MoonStar size={18} />
      </button>
    </div>
  </div>
  <div
    class="no-print container flex gap-1 overflow-x-auto pb-3 text-xs font-bold lg:hidden"
    aria-label="Mobile navigation"
  >
    <a class="nav-link shrink-0" href={withBase("/awards")}>Awards</a>
    <a class="nav-link shrink-0" href={withBase("/laureates")}>Laureates</a>
    <a class="nav-link shrink-0" href={withBase("/fields")}>Fields</a>
    <a class="nav-link shrink-0" href={withBase("/timeline")}>Timeline</a>
    <a class="nav-link shrink-0" href={withBase("/world-map")}>Map</a>
    <a class="nav-link shrink-0" href={withBase("/compare")}>Compare</a>
  </div>
</nav>

<script>
  const toggle = document.querySelector("[data-theme-toggle]");
  toggle?.addEventListener("click", () => {
    const next =
      document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("theme", next);
  });
</script>
