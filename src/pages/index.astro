---
import AwardCard from "@components/AwardCard.astro";
import LaureateCard from "@components/LaureateCard.astro";
import SearchBox from "@components/SearchBox.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { awards, fields, laureates, winnerRecords } from "@lib/catalog";

const featuredAwards = awards.slice(0, 6);
const featuredLaureates = laureates.slice(0, 6);
const recentWinners = [...winnerRecords]
  .sort((a, b) => b.year - a.year)
  .slice(0, 8);
---

<BaseLayout title="The Minds, Ideas and Honours That Shaped Mathematics">
  <section
    class="container grid items-center gap-10 py-12 lg:grid-cols-[1.05fr_.95fr] lg:py-14"
  >
    <div>
      <p class="eyebrow">Global mathematics awards archive</p>
      <h1 class="display-title mt-5">
        The Minds, Ideas and Honours That Shaped Mathematics
      </h1>
      <p class="mt-7 max-w-2xl text-xl leading-8 text-muted">
        Explore the world's major mathematics and statistics awards, the people
        who earned them, and the ideas that transformed human knowledge.
      </p>
      <div class="mt-8 max-w-2xl">
        <SearchBox />
      </div>
      <div class="mt-8 flex flex-wrap gap-3 text-sm font-bold">
        <a
          class="rounded-lg bg-obsidian px-5 py-3 text-ivory dark:bg-ivory dark:text-obsidian"
          href="/awards">Browse awards</a
        >
        <a
          class="rounded-lg border border-[var(--line)] px-5 py-3"
          href="/methodology">Read methodology</a
        >
      </div>
    </div>
    <div class="grid gap-4">
      <div class="card p-6">
        <p class="eyebrow">Data transparency</p>
        <p class="mt-4 font-display text-4xl leading-none">
          {awards.length} awards, {laureates.length} profiles
        </p>
        <p class="mt-4 text-sm leading-6 text-muted">
          Winner lists and biographies carry completeness labels. Partial
          datasets are not labelled complete.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="card p-5">
          <p class="text-3xl font-bold">{fields.length}</p>
          <p class="text-sm text-muted">research fields</p>
        </div>
        <div class="card p-5">
          <p class="text-3xl font-bold">{winnerRecords.length}</p>
          <p class="text-sm text-muted">winner records</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container py-12">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="eyebrow">Awards</p>
        <h2 class="section-title mt-3">Featured honours</h2>
      </div>
      <a
        class="text-sm font-bold underline decoration-[var(--accent)] decoration-2 underline-offset-4"
        href="/awards">All awards</a
      >
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {featuredAwards.map((award) => <AwardCard award={award} />)}
    </div>
  </section>

  <section class="container py-12">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="eyebrow">Laureates</p>
        <h2 class="section-title mt-3">Flagship profiles</h2>
      </div>
      <a
        class="text-sm font-bold underline decoration-[var(--accent)] decoration-2 underline-offset-4"
        href="/laureates">All profiles</a
      >
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        featuredLaureates.map((laureate) => (
          <LaureateCard laureate={laureate} />
        ))
      }
    </div>
  </section>

  <section class="container grid gap-8 py-12 lg:grid-cols-[.9fr_1.1fr]">
    <div>
      <p class="eyebrow">Timeline preview</p>
      <h2 class="section-title mt-3">Recent records</h2>
      <p class="mt-4 leading-7 text-muted">
        Use the full timeline to trace award creation, prize years, laureates,
        and research eras with an accessible text alternative.
      </p>
      <a
        class="mt-6 inline-flex rounded-lg border border-[var(--line)] px-5 py-3 text-sm font-bold"
        href="/timeline">Open timeline</a
      >
    </div>
    <ol class="card divide-y divide-[var(--line)]">
      {
        recentWinners.map((record) => (
          <li class="grid gap-2 p-4 sm:grid-cols-[5rem_1fr]">
            <>
              <span class="font-display text-2xl">{record.year}</span>
              <span>{record.recipientNames.join(", ")}</span>
            </>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="container grid gap-5 py-12 md:grid-cols-3">
    <a class="card p-6" href="/fields">
      <p class="eyebrow">Research-field explorer</p>
      <h2 class="mt-4 font-display text-3xl">
        From algebra to information science
      </h2>
    </a>
    <a class="card p-6" href="/world-map">
      <p class="eyebrow">Global map</p>
      <h2 class="mt-4 font-display text-3xl">
        Separate birthplace, affiliation, institution, and award country
      </h2>
    </a>
    <a class="card p-6" href="/inspiration">
      <p class="eyebrow">Pathways</p>
      <h2 class="mt-4 font-display text-3xl">Path to Mathematical Greatness</h2>
    </a>
  </section>
</BaseLayout>
